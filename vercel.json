{
  "version": 2,
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/cron/tweet",
      "schedule": "0 23 * * *"
    },
    {
      "path": "/api/cron/tweet",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
